ENVIRONMENT=development
LOG_LEVEL=INFO

# OCR
OCR_TRIGGER_CHAR_THRESHOLD=20
OCR_LANGUAGE=eng

# Classification
CLASSIFICATION_MIN_CONFIDENCE=0.55

# LLM (optional - only needed for low-confidence auto-classification fallback)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Embeddings (Milestone 3)
EMBEDDING_PROVIDER=bge
BGE_MODEL_NAME=BAAI/bge-large-en-v1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_API_KEY=

# Qdrant
QDRANT_MODE=local
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=legal_chunks
VECTOR_SEARCH_TOP_K=10

# Keyword search (Milestone 4)
KEYWORD_SEARCH_PROVIDER=bm25_local
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_INDEX_NAME=legal_chunks
KEYWORD_SEARCH_TOP_K=10

# Retriever: MMR diversity (Milestone 6)
MMR_LAMBDA=0.5
MMR_POOL_SIZE=20
RETRIEVER_TOP_K=8

# Re-ranking (Milestone 6)
RERANKER_PROVIDER=lightweight
RERANKER_MODEL_NAME=BAAI/bge-reranker-large
LIGHTWEIGHT_RERANK_ALPHA=0.5
RERANK_FINAL_TOP_K=5
RERANK_MIN_CONFIDENCE=0.15

# LLM / Answer generation (Milestone 7)
LLM_PROVIDER=anthropic
ANTHROPIC_QA_MODEL=claude-sonnet-4-6
OPENAI_QA_MODEL=gpt-4.1
GEMINI_QA_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0

# LLM / Answer generation (Milestone 7)
LLM_PROVIDER=anthropic
ANTHROPIC_QA_MODEL=claude-sonnet-4-6
OPENAI_QA_MODEL=gpt-4.1
GEMINI_QA_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0
GEMINI_API_KEY=
NO_EVIDENCE_PHRASE=I could not find supporting evidence.

# Rate limiting (Milestone 10)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
